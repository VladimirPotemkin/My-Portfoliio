{
  "printWidth": 150,
  "tabWidth": 2,
  "singleQuote": true,
  "semi": false,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "singleAttributePerLine": true,
  "overrides": [
    {
      "files": ["*.vue", "*.html"],
      "options": {
        "printWidth": 80,
        "singleAttributePerLine": true
      }
    }
  ]
}
